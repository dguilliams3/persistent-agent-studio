packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Coverage reports
coverage/

# Cloudflare Wrangler
.wrangler/
.mf/

# Environment files
.env
.env.local
.env.*.local

# Modal CLI credentials (token_id/token_secret) — never commit these
.modal.toml
**/.modal.toml

# Temp files from Claude/AI sessions
tmpclaude-*

# IDE/Editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Temporary JSON files
tmp_*.json
context_temp.json

# Wrangler cache
wrangler-account.json
cf.json
archive/claude-state-2026-01-09T14-19-23.json

# Test outputs (PONY image generation tests)
scripts/test_outputs/

