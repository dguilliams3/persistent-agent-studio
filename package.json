{
  "name": "persistent-claude",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "platforms/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:packages": "pnpm --filter @persistence/core build && pnpm --filter @persistence/embedding build && pnpm --filter @persistence/db build && pnpm --filter @persistence/media build && pnpm --filter @persistence/llm build && pnpm --filter @persistence/memory build && pnpm --filter @persistence/tools build && pnpm --filter @persistence/services build && pnpm --filter @persistence/ui build && pnpm --filter @persistence/runtime build",
    "clean:packages": "pnpm -r --filter './packages/*' run clean",
    "typecheck:packages": "pnpm -r --filter './packages/*' run typecheck",
    "typecheck:web": "pnpm exec tsc --noEmit -p apps/web/tsconfig.typecheck.json",
    "typecheck:worker": "pnpm exec tsc --noEmit -p platforms/cloudflare/tsconfig.json",
    "typecheck:budget": "node scripts/typecheck-budget.cjs",
    "preview": "vite preview",
    "pretest": "pnpm run build:packages",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "lint": "eslint apps/web/",
    "lint:fix": "eslint apps/web/ --fix",
    "lint:budget": "node scripts/lint-budget.cjs",
    "phantom-class:budget": "node scripts/phantom-class-budget.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "lucide-react": "^0.562.0",
    "plotly.js": "^3.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "remark-gfm": "^4.0.1",
    "tiktoken": "^1.0.22",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jpeg-js": "^0.4.4",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "undici": "^7.19.0",
    "upng-js": "^2.1.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.17"
  }
}
